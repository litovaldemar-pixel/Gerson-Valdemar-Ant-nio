{
  "entities": {
    "Transaction": {
      "title": "Transaction",
      "description": "A financial transaction (income or expense)",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "ID of the user who owns this transaction" },
        "date": { "type": "string", "description": "Date of the transaction" },
        "description": { "type": "string", "description": "Description of the transaction" },
        "category": { "type": "string", "description": "Category of the transaction" },
        "type": { "type": "string", "enum": ["receita", "despesa"], "description": "Type of transaction" },
        "value": { "type": "number", "description": "Value of the transaction" },
        "productId": { "type": "string", "description": "Optional product ID" },
        "quantity": { "type": "number", "description": "Optional quantity" },
        "customerId": { "type": "string", "description": "Optional customer ID" },
        "supplierId": { "type": "string", "description": "Optional supplier ID" },
        "receiptNumber": { "type": "number", "description": "Sequential receipt number" },
        "items": { 
          "type": "array", 
          "description": "Optional array of items for multi-item transactions",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "quantity": { "type": "number" },
              "unitPrice": { "type": "number" },
              "subtotal": { "type": "number" }
            }
          }
        }
      },
      "required": ["userId", "date", "description", "category", "type", "value"]
    },
    "Customer": {
      "title": "Customer",
      "description": "A customer of the company",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "ID of the user who owns this customer" },
        "name": { "type": "string", "description": "Name of the customer" },
        "email": { "type": "string", "format": "email", "description": "Email of the customer" },
        "document": { "type": "string", "description": "Document (CPF/CNPJ/NUIT)" },
        "status": { "type": "string", "description": "Status of the customer" }
      },
      "required": ["userId", "name", "email", "document", "status"]
    },
    "Supplier": {
      "title": "Supplier",
      "description": "A supplier of the company",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "ID of the user who owns this supplier" },
        "name": { "type": "string", "description": "Name of the supplier" },
        "email": { "type": "string", "format": "email", "description": "Email of the supplier" },
        "document": { "type": "string", "description": "Document (CPF/CNPJ/NUIT)" },
        "category": { "type": "string", "description": "Category of the supplier" }
      },
      "required": ["userId", "name", "email", "document", "category"]
    },
    "Product": {
      "title": "Product",
      "description": "A product sold by the company",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "ID of the user who owns this product" },
        "name": { "type": "string", "description": "Name of the product" },
        "sku": { "type": "string", "description": "SKU of the product" },
        "category": { "type": "string", "description": "Category of the product" },
        "price": { "type": "number", "description": "Selling price" },
        "cost": { "type": "number", "description": "Cost price" },
        "stock": { "type": "number", "description": "Current stock" },
        "minStock": { "type": "number", "description": "Minimum stock" }
      },
      "required": ["userId", "name", "sku", "category", "price", "cost", "stock", "minStock"]
    }
  },
  "firestore": {
    "transactions": {
      "schema": { "$ref": "#/entities/Transaction" },
      "description": "Collection of all transactions"
    },
    "customers": {
      "schema": { "$ref": "#/entities/Customer" },
      "description": "Collection of all customers"
    },
    "suppliers": {
      "schema": { "$ref": "#/entities/Supplier" },
      "description": "Collection of all suppliers"
    },
    "products": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Collection of all products"
    }
  }
}
