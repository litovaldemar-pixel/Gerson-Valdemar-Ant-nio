{
  "entities": {
    "CompanyInfo": {
      "title": "CompanyInfo",
      "description": "Information about a company",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "ID of the user who owns this company"
        },
        "name": {
          "type": "string",
          "description": "Name of the company"
        },
        "nuit": {
          "type": "string",
          "description": "NUIT of the company"
        },
        "contact": {
          "type": "string",
          "description": "Contact of the company"
        },
        "location": {
          "type": "string",
          "description": "Location of the company"
        },
        "subscription": {
          "type": "object",
          "description": "Subscription details",
          "properties": {
            "status": {
              "type": "string",
              "enum": ["active", "inactive", "pending"]
            },
            "validUntil": {
              "type": "string"
            },
            "plan": {
              "type": "string"
            },
            "price": {
              "type": "number"
            }
          }
        }
      },
      "required": ["userId", "name", "nuit", "contact", "location"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A financial transaction",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string"
        },
        "companyId": {
          "type": "string"
        },
        "date": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "category": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": ["receita", "despesa"]
        },
        "value": {
          "type": "number"
        },
        "productId": {
          "type": "string"
        },
        "quantity": {
          "type": "number"
        },
        "unitPrice": {
          "type": "number"
        },
        "customerId": {
          "type": "string"
        },
        "supplierId": {
          "type": "string"
        },
        "paymentMethod": {
          "type": "string"
        },
        "paymentStatus": {
          "type": "string",
          "enum": ["pago", "pendente"]
        },
        "receiptNumber": {
          "type": "number"
        },
        "items": {
          "type": "array"
        }
      },
      "required": ["userId", "date", "description", "category", "type", "value"]
    },
    "Customer": {
      "title": "Customer",
      "description": "A customer",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string"
        },
        "companyId": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "document": {
          "type": "string"
        },
        "status": {
          "type": "string"
        }
      },
      "required": ["userId", "name", "status"]
    },
    "Supplier": {
      "title": "Supplier",
      "description": "A supplier",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string"
        },
        "companyId": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "document": {
          "type": "string"
        },
        "category": {
          "type": "string"
        }
      },
      "required": ["userId", "name", "category"]
    },
    "Product": {
      "title": "Product",
      "description": "A product",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string"
        },
        "companyId": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "sku": {
          "type": "string"
        },
        "category": {
          "type": "string"
        },
        "price": {
          "type": "number"
        },
        "cost": {
          "type": "number"
        },
        "stock": {
          "type": "number"
        },
        "minStock": {
          "type": "number"
        }
      },
      "required": ["userId", "name", "sku", "category", "price", "cost", "stock", "minStock"]
    }
  },
  "firestore": {
    "/companies/{companyId}": {
      "schema": {
        "$ref": "#/entities/CompanyInfo"
      },
      "description": "Companies"
    },
    "/transactions/{transactionId}": {
      "schema": {
        "$ref": "#/entities/Transaction"
      },
      "description": "Transactions"
    },
    "/customers/{customerId}": {
      "schema": {
        "$ref": "#/entities/Customer"
      },
      "description": "Customers"
    },
    "/suppliers/{supplierId}": {
      "schema": {
        "$ref": "#/entities/Supplier"
      },
      "description": "Suppliers"
    },
    "/products/{productId}": {
      "schema": {
        "$ref": "#/entities/Product"
      },
      "description": "Products"
    }
  }
}